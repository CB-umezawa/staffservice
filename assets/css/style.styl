// /* mixin & Variable */

MQ_MAX(maxWidth){
	@media screen and (max-width: maxWidth) {
		{block}
	}

}

MQ_MIN(minWidth){
	@media screen and (min-width: minWidth) {
		{block}
	}

}

MQ_MIN_MAX(minWidth,maxWidth){
	@media screen and (min-width:minWidth) and (max-width:maxWidth) {
		{block}
	}

}

MQ_HOVER()
	+MQ_MIN(RES_WID_PC01)
		&:hover
			{block}

CF()
	+cache('clearfix')
		&::after
			content: "";
			display: block;
			clear: both;

fontSet()
	font-family: DF_FONT;
	fontSize(15);
	line-height: 1.6;
	-webkit-text-size-adjust: 100%;

	+MQ_MAX(RES_WID_SMALL01)
		fontSize(13);

fontSize(size) {
	font-size: (size) px;
	font-size: (size / 10) rem;
}

vwsp(size)
	rate = 100 / 375;
	return rate * size * 1vw

vwpc(size)
	rate = 100 / 1400;
	return rate * size * 1vw

fontSp(font_size)
	font-size: font_size * 1px;
	font-size: vwsp(font_size);

fontPc(font_size)
	font-size: font_size * 1px;
	font-size: vwpc(font_size);

vwFontSet(font_size)
	+MQ_MAX(PC_RES_WID01)
		fontPc(font_size)
	+MQ_MIN(PC_RES_WID01)
		fontSize(font_size)

pSet(px)
	return px / 1000 * 100 * 1%

fontLato()
	font-family: 'Lato', sans-serif;


/* ベース
---------------------------------- */

html
	height 100%
	font-size 62.5%
	scroll-padding-top var(--header-height, $HEADER_H)

[id]
	scroll-margin-top var(--header-height, $HEADER_H)

body
	-webkit-text-size-adjust 100%
	min-height 100%
	height 100%
	+MQ_MAX(RES_WID_SMALL01)
		min-width 0px

	background-color DF_BG_COLOR
	color DF_TEXT_COLOR

	fontSet()

	input[type="text"], input[type="button"], button, textarea
		margin 0
		padding 0
		background none
		border none
		border-radius 0
		outline none
		-webkit-appearance none
		-moz-appearance none
		appearance none
		resize none

	input[type="text"], select, textarea
		width 100%

	input[type="radio"], input[type="checkbox"]
		margin 0

	input, select, textarea, button
		fontSet()

	::selection
		background-color SITE_COLOR01
		color #ffffff

	+MQ_MAX(RES_WID_SMALL01)
		width 100%
		min-width 0

	&.is-header02Open
		overflow hidden

a
	color inherit
	text-decoration none !important
	&:link, &:visited
		color #005bac
		text-decoration underline
	&:active
		text-decoration none
	+MQ_HOVER()
		text-decoration none
	&:focus
		outline none

.is-pcOnly
	+MQ_MAX(RES_WID_SMALL01)
		display none
.is-spOnly
	display none
	+MQ_MAX(RES_WID_SMALL01)
		display block


